  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      width: 100%;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #0f766e 0%, #134e4a 100%);
      overflow: auto;
    }

    .app-wrapper {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: linear-gradient(135deg, #0f766e 0%, #134e4a 100%);
    }

    .container {
      width: 100%;
      max-width: 900px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
      color: white;
      padding: 40px 30px;
      text-align: center;
    }

    .header h1 {
      font-size: 32px;
      margin-bottom: 10px;
      font-weight: 700;
    }

    .header p {
      font-size: 16px;
      opacity: 0.95;
    }

    .button-section {
      display: flex;
      gap: 12px;
      justify-content: center;
      padding: 30px;
      background: #f0fdf4;
      border-bottom: 1px solid #e5e7eb;
    }

    .btn {
      padding: 12px 28px;
      font-size: 14px;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-download {
      background: #0d9488;
      color: white;
    }

    .btn-download:hover {
      background: #0f766e;
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(13, 148, 136, 0.3);
    }

    .btn-print {
      background: #e0f2fe;
      color: #0369a1;
    }

    .btn-print:hover {
      background: #bae6fd;
      transform: translateY(-2px);
    }

    .content {
      padding: 40px;
      max-height: 70vh;
      overflow-y: auto;
    }

    .section {
      margin-bottom: 35px;
    }

    .section-title {
      font-size: 22px;
      color: #0d9488;
      font-weight: 700;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-content {
      color: #374151;
      line-height: 1.8;
      font-size: 15px;
    }

    .goals-box {
      background: #f0fdf4;
      border-left: 4px solid #0d9488;
      padding: 20px;
      margin-bottom: 20px;
      border-radius: 6px;
    }

    .goals-box h3 {
      color: #0d9488;
      font-size: 16px;
      margin-bottom: 12px;
    }

    .goal-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 8px;
      color: #1f2937;
    }

    .goal-item strong {
      color: #0f766e;
    }

    .dua-box {
      background: #fef7e7;
      border-left: 4px solid #d4a574;
      padding: 15px;
      margin: 15px 0;
      border-radius: 6px;
      font-style: italic;
    }

    .dua-arabic {
      color: #b91c1c;
      font-size: 16px;
      font-weight: 500;
      margin-bottom: 10px;
      font-family: 'Arial', sans-serif;
    }

    .dua-transliteration {
      color: #7c3aed;
      font-size: 13px;
      margin-bottom: 8px;
    }

    .dua-translation {
      color: #374151;
      font-size: 14px;
    }

    .table-section {
      margin: 20px 0;
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    th, td {
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid #e5e7eb;
    }

    th {
      background: #f3f4f6;
      font-weight: 600;
      color: #0f766e;
    }

    tr:hover {
      background: #f9fafb;
    }

    .routine-box {
      background: #ecfdf5;
      padding: 15px;
      margin: 12px 0;
      border-radius: 6px;
      border-left: 3px solid #10b981;
    }

    .routine-box strong {
      color: #0d9488;
      display: block;
      margin-bottom: 8px;
    }

    .routine-box p {
      color: #374151;
      line-height: 1.6;
    }

    .footer {
      text-align: center;
      padding: 20px;
      background: #f9fafb;
      border-top: 1px solid #e5e7eb;
      color: #6b7280;
      font-size: 13px;
    }

    .divider {
      height: 2px;
      background: linear-gradient(90deg, transparent, #0d9488, transparent);
      margin: 25px 0;
    }

    @media print {
      .button-section {
        display: none;
      }
      body {
        background: white;
      }
      .app-wrapper {
        background: white;
        padding: 0;
      }
    }
  </style>
